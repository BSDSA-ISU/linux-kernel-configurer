# mkinitcpio preset file for the 'Ai-Hoshino' package

#ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-koishi"

PRESETS=('default' 'fallback')

#default_config="/etc/mkinitcpio.conf"
default_image="/boot/initramfs-koishi.img"

#fallback_config="/etc/mkinitcpio.conf"
fallback_image="/boot/initramfs-koishi-fallback.img"
#fallback_uki="/efi/EFI/Linux/arch-Ai-Hoshino-fallback.efi"
fallback_options="-S autodetect"
