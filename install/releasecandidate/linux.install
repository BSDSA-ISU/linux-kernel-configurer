post_install() {
    echo ":: Running mkinitcpio for linux-koishi..."
    mkinitcpio -p linux-koishi
}

post_upgrade() {
    echo ":: Running mkinitcpio for linux-koishi..."
    mkinitcpio -p linux-koishi    
}

pre_remove() {
    echo ":: Removing initramfs for linux-Koishi..."
    rm -f /boot/initramfs-koishi.img /boot/initramfs-koishi-fallback.img
}
